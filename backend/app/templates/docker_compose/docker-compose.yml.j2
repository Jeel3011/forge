# docker-compose.yml — generated by Forge for {{ project_type }}
# Scale: {{ scale }} | Generated: auto

version: "3.9"

services:
  api:
    build: .
    ports:
      - "8000:8000"
    env_file: .env
    healthcheck:
      test: ["CMD", "curl", "-f", "http://localhost:8000/health"]
      interval: 30s
      timeout: 10s
      retries: 3
      start_period: 20s
    deploy:
      resources:
        limits:
          memory: {{ memory_limit }}
    restart: unless-stopped
    {% if needs_redis %}
    depends_on:
      - redis
    {% endif %}

{% if needs_celery %}
  worker:
    build: .
    command: celery -A app.celery worker --concurrency={{ workers }} -Q default --time-limit={{ celery_time_limit }} --soft-time-limit={{ celery_time_limit - 60 }}
    env_file: .env
    deploy:
      resources:
        limits:
          memory: {{ memory_limit }}
    restart: unless-stopped
    depends_on:
      - redis
{% endif %}

{% if needs_redis %}
  redis:
    image: redis:7-alpine
    command: redis-server --maxmemory 512mb --maxmemory-policy allkeys-lru
    volumes:
      - redis_data:/data
    restart: unless-stopped
{% endif %}

{% if needs_qdrant %}
  qdrant:
    image: qdrant/qdrant:latest
    ports:
      - "6333:6333"
    volumes:
      - qdrant_data:/qdrant/storage
    restart: unless-stopped
{% endif %}

{% if needs_gpu %}
  # GPU-enabled service — requires nvidia-container-toolkit on the host
  gpu-worker:
    build: .
    runtime: nvidia
    environment:
      - NVIDIA_VISIBLE_DEVICES=all
    command: python worker.py
    env_file: .env
    restart: unless-stopped
{% endif %}

volumes:
{% if needs_redis %}
  redis_data:
{% endif %}
{% if needs_qdrant %}
  qdrant_data:
{% endif %}
